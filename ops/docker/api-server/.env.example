TZ=Asia/Shanghai

API_SERVER_PORT=8080
API_SERVER_VERSION=dev-docker
API_SERVER_AUTH_ACCESS_TOKEN_TTL=24h
API_SERVER_IAM_BACKEND=mysql_redis
API_SERVER_CAMPUS_LIFE_BACKEND=mongo
API_SERVER_PORTAL_BACKEND=mongo
API_SERVER_NOTIFICATION_BACKEND=mongo
API_SERVER_ANALYTICS_BACKEND=mongo
API_SERVER_AUTO_MIGRATE=true

MYSQL_PORT=3306
MYSQL_DB=weouc
MYSQL_USER=weouc
MYSQL_PASSWORD=weouc
MYSQL_ROOT_PASSWORD=root
API_SERVER_MYSQL_HEALTHCHECK_TIMEOUT=2s

MONGO_PORT=27017
MONGO_DB=weouc
API_SERVER_MONGO_HEALTHCHECK_TIMEOUT=2s

REDIS_PORT=6379
API_SERVER_REDIS_DB=0
API_SERVER_REDIS_HEALTHCHECK_TIMEOUT=2s

API_SERVER_COS_ENABLED=false
API_SERVER_COS_SECRET_ID=
API_SERVER_COS_SECRET_KEY=
API_SERVER_COS_BUCKET=
API_SERVER_COS_REGION=
API_SERVER_COS_PATH_PREFIX=miniapp
API_SERVER_COS_STS_DURATION=1h
API_SERVER_COS_PRESIGNED_GET_TTL=6h
API_SERVER_COS_HEALTHCHECK_TIMEOUT=2s
