API_SERVER_NAME=api-server
API_SERVER_ENV=local
API_SERVER_VERSION=dev

API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8080
API_SERVER_READ_TIMEOUT=5s
API_SERVER_WRITE_TIMEOUT=10s
API_SERVER_SHUTDOWN_TIMEOUT=10s

API_SERVER_AUTH_USER_ID_HEADER=X-User-ID
API_SERVER_AUTH_ROLES_HEADER=X-User-Roles
API_SERVER_AUTH_PERMISSIONS_HEADER=X-User-Permissions
API_SERVER_AUTH_ACADEMIC_BOUND_HEADER=X-Academic-Bound
API_SERVER_AUTH_ACCESS_TOKEN_TTL=24h

API_SERVER_POSTGRES_ENABLED=false
API_SERVER_POSTGRES_HOST=127.0.0.1
API_SERVER_POSTGRES_PORT=5432
API_SERVER_POSTGRES_DATABASE=weouc
API_SERVER_POSTGRES_USER=weouc
API_SERVER_POSTGRES_PASSWORD=weouc
API_SERVER_POSTGRES_SSL_MODE=disable
API_SERVER_POSTGRES_HEALTHCHECK_TIMEOUT=2s

API_SERVER_REDIS_ENABLED=false
API_SERVER_REDIS_HOST=127.0.0.1
API_SERVER_REDIS_PORT=6379
API_SERVER_REDIS_USERNAME=
API_SERVER_REDIS_PASSWORD=
API_SERVER_REDIS_DB=0
API_SERVER_REDIS_HEALTHCHECK_TIMEOUT=2s

API_SERVER_COS_ENABLED=false
API_SERVER_COS_SECRET_ID=your-secret-id
API_SERVER_COS_SECRET_KEY=your-secret-key
API_SERVER_COS_BUCKET=bucket-appid
API_SERVER_COS_REGION=ap-guangzhou
API_SERVER_COS_PATH_PREFIX=miniapp
API_SERVER_COS_STS_DURATION=1h
API_SERVER_COS_PRESIGNED_GET_TTL=6h
API_SERVER_COS_HEALTHCHECK_TIMEOUT=2s

API_SERVER_IAM_BACKEND=memory
API_SERVER_CAMPUS_LIFE_BACKEND=memory
API_SERVER_AUTO_MIGRATE=false
