<view
  class="common-empty-state custom-class"
  style="min-height: {{minHeight}}rpx; --common-empty-icon-color: {{iconColor}}; --common-empty-icon-bg: {{iconBackground}}; --common-empty-action-bg: {{actionBackground}};"
>
  <view class="common-empty-state__icon">
    <t-icon name="{{icon}}" size="{{iconSize}}" />
  </view>
  <view class="common-empty-state__title">{{title}}</view>
  <view wx:if="{{description}}" class="common-empty-state__desc">{{description}}</view>
  <view
    wx:if="{{actionText}}"
    class="common-empty-state__button"
    hover-class="tap-button"
    bindtap="onAction"
  >
    {{actionText}}
  </view>
</view>
