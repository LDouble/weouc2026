<view class="login-page">
  <common-page-header
    title="微信登录"
    background="rgba(247, 250, 252, 0.88)"
    border-color="rgba(226, 232, 240, 0.9)"
    button-background="#ffffff"
    showBack="{{true}}"
    bind:back="onBack"
  />

  <view class="login-content">
    <view class="login-hero">
      <view class="login-hero__badge">校园统一入口</view>
      <view class="login-hero__title">使用微信一键建立校园会话</view>
      <view class="login-hero__desc">登录只负责建立会话；联系方式、教务能力等受限信息，仍由后端按绑定状态裁剪返回。</view>
    </view>

    <view class="login-card">
      <view class="login-benefits">
        <view class="login-benefit">
          <view class="login-benefit__icon login-benefit__icon--green">
            <t-icon name="logo-wechat" size="30rpx" />
          </view>
          <view class="login-benefit__body">
            <view class="login-benefit__title">微信默认登录</view>
            <view class="login-benefit__desc">与项目主登录链路保持一致</view>
          </view>
        </view>

        <view class="login-benefit">
          <view class="login-benefit__icon login-benefit__icon--blue">
            <t-icon name="lock-on" size="30rpx" />
          </view>
          <view class="login-benefit__body">
            <view class="login-benefit__title">权限后端裁决</view>
            <view class="login-benefit__desc">前端只渲染已授权的能力</view>
          </view>
        </view>

        <view class="login-benefit">
          <view class="login-benefit__icon login-benefit__icon--amber">
            <t-icon name="education" size="30rpx" />
          </view>
          <view class="login-benefit__body">
            <view class="login-benefit__title">教务绑定可后补</view>
            <view class="login-benefit__desc">在“我的”中完成教务绑定即可解锁受限能力</view>
          </view>
        </view>
      </view>

      <view class="login-agreement" hover-class="tap-button" bindtap="onCheckChange">
        <view class="login-agreement__check {{isCheck ? 'login-agreement__check--active' : ''}}">
          <t-icon wx:if="{{isCheck}}" name="check" size="24rpx" color="#ffffff" />
        </view>
        <view class="login-agreement__text">
          我已阅读并同意《用户协议》与《隐私政策》
        </view>
      </view>

      <t-button
        theme="primary"
        size="large"
        block
        loading="{{isLoading}}"
        disabled="{{!isCheck || isLoading}}"
        bindtap="onWxLogin"
      >
        使用微信一键登录
      </t-button>

      <view class="login-tip">登录后默认进入首页，教务绑定、个人资料和设置在“我的”中统一管理。</view>
    </view>
  </view>
</view>
