page {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 112rpx);
  background:
    radial-gradient(circle at 12% 0%, rgba(99, 102, 241, 0.18), transparent 34%),
    radial-gradient(circle at 90% 10%, rgba(236, 72, 153, 0.12), transparent 30%),
    linear-gradient(135deg, #f8f7ff 0%, #eef2ff 52%, #fdf2f8 100%);
}

.message-list {
  height: 0;
  flex-grow: 1;
  margin: 20rpx 24rpx 0;
  padding: 16rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 20px;
  overflow: hidden;
  background-color: rgba(255, 255, 255, 0.78);
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.08);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.message-state {
  padding: 120rpx 0;
  text-align: center;
  color: #909399;
  font-size: 26rpx;
}

.message-card {
  position: relative;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #eceffe;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.86);
}

.message-card--unread {
  border-color: rgba(99, 102, 241, 0.22);
  box-shadow: 0 10rpx 28rpx rgba(99, 102, 241, 0.08);
}

.message-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.message-card__title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a44;
  line-height: 1.4;
}

.message-card__time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #8f96a3;
}

.message-card__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.message-card__tag {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 20rpx;
}

.message-card__dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #fb2c36;
}

.message-card__content {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #444f62;
  line-height: 1.55;
}

.message-footer {
  padding: 20rpx 0 8rpx;
  text-align: center;
}

.message-footer__text {
  color: #8f96a3;
  font-size: 24rpx;
}

.message-footer__text--done {
  color: #9ca3af;
}

.message-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.message-empty__icon {
  margin-bottom: 32rpx;
}

.message-empty__text {
  font-size: 28rpx;
  color: #909399;
}
