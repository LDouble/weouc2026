/* pages/message/message.wxss */
page {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 112rpx);
  background:
    radial-gradient(circle at 12% 0%, rgba(99, 102, 241, 0.18), transparent 34%),
    radial-gradient(circle at 90% 10%, rgba(236, 72, 153, 0.12), transparent 30%),
    linear-gradient(135deg, #f8f7ff 0%, #eef2ff 52%, #fdf2f8 100%);
}
.nav-bar {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.68);
}
.message-list {
  height: 0;
  flex-grow: 1;
  margin: 20rpx 24rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 20px;
  overflow: hidden;
  background-color: rgba(255, 255, 255, 0.78);
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.08);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}
.avatar {
  border-radius: 50% !important;
}
.content > view {
  width: 560rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.content.unread > view {
  width: 510rpx;
}
.message-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}
.message-empty__icon {
  margin-bottom: 32rpx;
}
.message-empty__text {
  font-size: 28rpx;
  color: #909399;
}
