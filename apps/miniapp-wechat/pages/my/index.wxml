<view class="my-page">
  <view class="my-bg"></view>

  <common-page-header
    title="我的"
    background="rgba(245, 243, 255, 0.88)"
    border-color="rgba(238, 242, 255, 0.9)"
    button-background="#eef2ff"
    showBack="{{false}}"
    bind:back="onBack"
    bind:heightchange="onHeaderHeightChange"
  />

  <view class="my-content" style="padding-top: {{headerHeight}}px;">
    <view class="my-profile">
      <view wx:if="{{isLoad}}" class="my-profile__inner">
        <view class="my-profile__avatar-wrap">
          <view class="my-profile__avatar-frame">
            <t-avatar image="{{personalInfo.image}}" size="120rpx" />
          </view>
          <view class="my-profile__badge">
            <t-icon name="star-filled" size="16rpx" color="#fff" />
          </view>
        </view>
        <view class="my-profile__body">
          <view class="my-profile__name">{{personalInfo.name}}</view>
          <view class="my-profile__tags">
            <view class="my-pill my-pill--primary">{{personalInfo.major || '计算机科学'}}</view>
            <view class="my-pill my-pill--muted">{{personalInfo.sid || '2021008129'}}</view>
          </view>
        </view>
        <view class="my-profile__edit" hover-class="tap-button" bindtap="onNavigateTo">
          <t-icon name="edit" size="32rpx" color="#6366f1" />
        </view>
      </view>

      <view wx:if="{{!isLoad}}" class="my-profile__inner my-profile__inner--login">
        <t-avatar icon="user" size="96rpx" />
        <view class="my-profile__login-text">登录后享受更多服务</view>
        <view class="my-profile__login-btn" hover-class="tap-button" bindtap="onLogin">立即登录</view>
      </view>
    </view>

    <view class="my-stats">
      <view wx:for="{{stats}}" wx:key="key" class="my-stat my-stat--{{item.bg}}">
        <view class="my-stat__icon">
          <t-icon name="{{item.icon}}" size="28rpx" />
        </view>
        <view class="my-stat__value">{{item.value}}</view>
        <view class="my-stat__label">{{item.label}}</view>
      </view>
    </view>

    <view class="my-section">
      <view class="my-section__head">
        <view class="my-section__left">
          <text>我的服务</text>
        </view>
      </view>
      <view class="my-menu">
        <view
          wx:for="{{serviceList}}"
          wx:key="type"
          class="my-menu__item"
          data-data="{{item}}"
          hover-class="tap-button"
          bindtap="onEleClick"
        >
          <view class="my-menu__left">
            <view class="my-menu__icon my-menu__icon--{{item.type}}">
              <t-icon name="{{item.icon}}" size="28rpx" />
            </view>
            <text class="my-menu__name">{{item.name}}</text>
          </view>
          <t-icon name="chevron-right" size="32rpx" color="#c0c4cc" />
        </view>
      </view>
    </view>

    <view class="my-section">
      <view class="my-section__head">
        <view class="my-section__left">
          <text>设置与帮助</text>
        </view>
      </view>
      <view class="my-menu">
        <view
          wx:for="{{settingList}}"
          wx:key="type"
          class="my-menu__item"
          data-data="{{item}}"
          hover-class="tap-button"
          bindtap="onEleClick"
        >
          <view class="my-menu__left">
            <view class="my-menu__icon my-menu__icon--{{item.type}}">
              <t-icon name="{{item.icon}}" size="28rpx" />
            </view>
            <text class="my-menu__name">{{item.name}}</text>
          </view>
          <view class="my-menu__right">
            <view wx:if="{{item.badge}}" class="my-menu__badge">{{item.badge}}</view>
            <t-icon name="chevron-right" size="32rpx" color="#c0c4cc" />
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<t-toast id="t-toast" />
